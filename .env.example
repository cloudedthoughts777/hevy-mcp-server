# Hevy API Configuration
# Get your API key at: https://hevy.com/settings?developer
HEVY_API_KEY=your_hevy_api_key_here
HEVY_API_BASE_URL=https://api.hevyapp.com

# Transport Configuration
#   http  - Streamable HTTP (MCP spec 2025-03-26) - REQUIRED for Claude/claude.ai connectors
#   stdio - local stdin/stdout (Claude Desktop)
#   sse   - legacy HTTP+SSE transport (DEPRECATED, kept for old clients only)
#   both  - stdio + http
TRANSPORT=http                     # http | stdio | sse | both
PORT=3004                          # Port for http/sse mode
HOST=127.0.0.1                     # Host for http/sse mode

# Endpoint path for http/sse mode
MCP_PATH=/mcp                      # MCP endpoint path (SSE_PATH still honored as a fallback)
HEARTBEAT_INTERVAL=30000           # ms - keep-alive, legacy SSE transport only

# Security: AUTH_TOKEN (recommended when exposing over the public internet)
# - OPTIONAL: For local development (localhost only)
# Generate a secure token with: npm run generate-token
AUTH_TOKEN=                        # Leave empty for no auth, or set a secure random token

# Session Management
SESSION_TIMEOUT=2592000000         # Session timeout in ms, legacy SSE transport only (default: 30 days)

# HTTPS/TLS Configuration (only needed when terminating TLS in-process)
ENABLE_HTTPS=false                 # Set to true to enable HTTPS
HTTPS_KEY_PATH=                    # Path to SSL private key file (e.g., /path/to/privkey.pem)
HTTPS_CERT_PATH=                   # Path to SSL certificate file (e.g., /path/to/fullchain.pem)

# Production Environment
NODE_ENV=development               # Set to 'production' for production deployments

# Note: ngrok is run separately via CLI: ngrok http 3000
# The server does not manage ngrok automatically
